# Database
DATABASE_URL="postgresql://arc:arc_dev@localhost:5432/arc_dev?schema=public"

# Auth (min 16 chars each)
JWT_SECRET="change-me-in-production-min16"
JWT_REFRESH_SECRET="change-me-in-production-refresh-min16"

# Stripe Connect
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
